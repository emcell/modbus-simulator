# Example environment file. Copy to `.env` (gitignored) for local dev.
#
#   cp .env.example .env
#
# The Rust backend loads `.env` from the current working directory at
# startup via `dotenvy`. All variables are optional; the defaults are
# fine for a user who just wants to double-click the binary and get a
# working Modbus simulator.

# Auto-open the system browser when the HTTP server is ready. Enabled by
# default so end-users don't have to copy/paste URLs from the log.
# Developers iterating with `cargo run` usually want this OFF since
# they already have the tab open.
MODSIM_OPEN_BROWSER=false

# HTTP bind address. Default is 0.0.0.0 (reachable from the LAN).
# Set to 127.0.0.1 to restrict to loopback.
# MODSIM_HTTP_BIND=127.0.0.1

# HTTP port. Default is 8080 unless changed in settings.json.
# MODSIM_HTTP_PORT=8080

# Persisted state directory. By default modsim uses the OS-specific
# config dir (e.g. ~/Library/Application Support/dev.emcell.modbus-simulator
# on macOS). Override for isolated dev runs.
# MODSIM_CONFIG_DIR=/tmp/modsim-dev

# Log filter — same syntax as tracing/env_logger.
# RUST_LOG=modsim_server=debug,info
